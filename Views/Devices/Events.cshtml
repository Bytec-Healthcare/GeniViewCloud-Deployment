@model GeniView.Cloud.Models.DeviceEventLogFilter
@using GeniView.Cloud.Models;
@{
    ViewBag.Title = "Events History";
    ViewBag.ShowCommunityAndGroupFilter = true;
}
<link rel="stylesheet" type="text/css" href="~/Content/jquery.datetimepicker.min.css" />

<style>
    /* Page-scoped UX styling (kept local to avoid impacting other pages) */
    .gv-device-events {
        font-family: "Instrument Sans", -apple-system, BlinkMacSystemFont, "Segoe UI", "Roboto", sans-serif;
    }

        /* Top bar (Event History + Refresh) */
        .gv-device-events .gv-events-topbar {
            width: 100%;
            max-width: 1280px;
            height: 42px;
            background: rgba(180, 191, 255, 0.65);
            border: 1px solid rgba(62, 76, 193, 0.55);
            border-radius: 10px;
            padding: 0 16px;
            display: flex;
            align-items: center;
            box-sizing: border-box;
            margin-bottom: 14px;
        }

        .gv-device-events .gv-events-topbar__title {
            font-weight: 700;
            font-size: 15px;
            color: rgba(62, 76, 193, 1);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .gv-device-events .gv-events-topbar__spacer {
            margin-left: auto;
        }

        /* Refresh button (reuse same look as other pages using .refresh-btn) */
        .gv-device-events .refresh-btn {
            background: transparent !important;
            border: none !important;
            padding: 0 !important;
            margin: 0 !important;
            box-shadow: none !important;
            line-height: 1 !important;
            color: rgba(62, 76, 193, 1) !important;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 13px;
            font-weight: 600;
            white-space: nowrap;
        }

            .gv-device-events .refresh-btn:hover {
                text-decoration: underline;
            }

        .gv-device-events .refresh-icon {
            font-size: 14px;
        }

        /* Cards (same as Device History pattern) */
        .gv-device-events .gv-card {
            background: #fff;
            border: 1px solid #e6e9ef;
            border-radius: 12px;
            box-shadow: 0 6px 18px rgba(16, 24, 40, 0.14);
            max-width: 1266px;
            width: 100%;
        }

        .gv-device-events .gv-card__header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 16px;
            border-bottom: 1px solid #eef1f6;
            cursor: pointer;
            user-select: none;
        }

        .gv-device-events .gv-card__title {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-size: 16px;
            font-weight: 700;
            color: #111827;
        }

        .gv-device-events .gv-card__chevron {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 28px;
            height: 28px;
            border-radius: 6px;
            border: 1px solid #e6e9ef;
            background: #fff;
            color: #111827;
            flex: 0 0 auto;
            overflow: hidden;
        }

            .gv-device-events .gv-card__chevron img {
                width: 14px;
                height: 14px;
                display: block;
                transition: transform 0.15s ease;
            }

        .gv-device-events .gv-icon {
            width: 16px;
            height: 16px;
            vertical-align: middle;
        }

        .gv-device-events .gv-card__body {
            padding: 14px 16px 16px 16px;
            min-height: 140px;
            box-sizing: border-box;
        }

        .gv-device-events .gv-card.is-collapsed .gv-card__body {
            display: none;
        }

        .gv-device-events .gv-card.is-collapsed .gv-card__chevron img {
            transform: rotate(180deg);
        }

        /* Filters grid */
        .gv-device-events .gv-filters-grid {
            display: grid;
            grid-template-columns: 236px 236px 236px 138px;
            gap: 24px;
            align-items: end;
            justify-content: space-between;
        }

        .gv-device-events .gv-field label {
            display: block;
            margin: 0 0 10px 0;
            font-weight: 500;
            font-size: 13px;
            line-height: 100%;
            color: #374151;
        }

        .gv-device-events .gv-input {
            width: 236px;
            border: 1px solid #d5dbe7;
            border-radius: 7px;
            padding: 10px 12px;
            font-size: 13px;
            color: #111827;
            outline: none;
            box-sizing: border-box;
            background: #fff;
            max-width: 100%;
        }

        .gv-device-events .gv-input--date {
            height: 42px;
            padding-right: 44px;
        }

        .gv-device-events .gv-input--count {
            height: 50px;
        }

        .gv-device-events .gv-input:focus {
            border-color: #3e4cc1;
            box-shadow: 0 0 0 3px rgba(62, 76, 193, 0.15);
        }

        .gv-device-events .gv-input-icon {
            position: relative;
            width: 236px;
            max-width: 100%;
        }

        .gv-device-events .gv-input-icon__suffix {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 18px;
            height: 18px;
            pointer-events: none;
            opacity: 0.9;
        }

            .gv-device-events .gv-input-icon__suffix img {
                width: 16px;
                height: 16px;
                display: block;
            }

        .gv-device-events .gv-btn {
            border: 1px solid transparent;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            box-sizing: border-box;
            white-space: nowrap;
        }

        .gv-device-events .gv-btn--primary {
            width: 138px;
            height: 42px;
            border-radius: 7px;
            padding: 10px 18px;
            gap: 10px;
            background: #3e4cc1;
            border-color: #3e4cc1;
            color: #fff;
            font-size: 16px;
            font-weight: 700;
        }

            .gv-device-events .gv-btn--primary:hover {
                background: #3541b0;
                border-color: #3541b0;
            }

        /* Event List bar (blue bar + search + download) */
        .gv-device-events .gv-serial-bar {
            margin-top: 14px;
            max-width: 1280px;
            width: 100%;
            height: 63px;
            background: rgba(211, 215, 245, 0.78);
            border: 1px solid #d9ddff;
            border-radius: 10px;
            padding: 9px 14px;
            display: flex;
            align-items: center;
            gap: 18px;
            box-sizing: border-box;
        }

        .gv-device-events .gv-serial-bar__left {
            width: 344px;
            height: 29px;
            font-weight: 700;
            font-size: 20px;
            line-height: 100%;
            color: rgba(62, 76, 193, 1);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            flex: 0 0 auto;
        }

        .gv-device-events .gv-search {
            position: relative;
            width: 640px;
            height: 45px;
            flex: 0 0 auto;
        }

            .gv-device-events .gv-search .fa {
                position: absolute;
                left: 19px;
                top: 50%;
                transform: translateY(-50%);
                font-size: 14px;
                color: #6b7280;
            }

            .gv-device-events .gv-search input {
                width: 640px;
                height: 45px;
                border-radius: 8px;
                padding: 10px 12px 10px 42px;
                border: 1px solid #d5dbe7;
                box-sizing: border-box;
                font-size: 13px;
            }

                .gv-device-events .gv-search input:focus {
                    border-color: #3e4cc1;
                    box-shadow: 0 0 0 3px rgba(62, 76, 193, 0.15);
                    outline: none;
                }

        .gv-device-events #gvEventDownload.gv-btn--primary {
            width: 146px;
            height: 37px;
            border-radius: 7px;
            padding: 10px 18px;
            line-height: normal;
            margin-left: auto;
            flex: 0 0 auto;
        }

        /* Table container + table */
        .gv-device-events .gv-table-scroll {
            overflow-x: auto;
            border-radius: 10px;
        }

        .gv-device-events table.gv-table {
            width: max-content;
            min-width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            table-layout: auto;
        }

            /* 1) Horizontal separator under header must span full width */
            .gv-device-events table.gv-table thead th {
                position: sticky;
                top: 0;
                z-index: 2;
                background: #fff;
                font-weight: 700;
                font-size: 14px;
                line-height: 1.2;
                color: #111827;
                padding: 12px 14px;
                border-bottom: 2px solid #d5dbe7; /* bolder, full-width header separator */
                text-align: center;
                vertical-align: middle;
                white-space: nowrap;
            }

            /* No vertical separators between columns (per updated requirement) */
            .gv-device-events table.gv-table thead th,
            .gv-device-events table.gv-table tbody td {
                border-right: 0 !important;
            }

            .gv-device-events table.gv-table tbody td {
                padding: 10px 14px;
                border-bottom: 1px solid #f1f3f8;
                text-align: center;
                vertical-align: middle;
                line-height: 1.35;
                white-space: nowrap;
                color: #4b5563;
                font-weight: 500;
            }

        /* 2) Inline cell icon + text (2px gap, aligned, icon autosized to text) */
        .gv-device-events .gv-cell-prefix {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 2px;
            width: 100%;
        }

            .gv-device-events .gv-cell-prefix img {
                height: 1em; /* auto match text height */
                width: auto;
                display: inline-block;
                vertical-align: middle;
                flex: 0 0 auto;
            }

        /* Keep existing timestamp styling but align to requested 2px gap as well */
        .gv-device-events .gv-cell-inline {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 2px; /* was 6px; requirement says 2px */
            width: 100%;
        }

            .gv-device-events .gv-cell-inline img {
                height: 1em;
                width: auto;
                display: inline-block;
                vertical-align: middle;
                flex: 0 0 auto;
            }

        /* Pagination footer (match Device History design) */
        .gv-device-events .gv-dt-info {
            width: 198px;
            height: 20px;
            font-weight: 500;
            font-size: 16px;
            line-height: 100%;
            color: #6b7280;
            white-space: nowrap;
        }

        .gv-device-events #gvEventPagerHost .gv-dt-footer {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 12px 0 0 0;
            background: transparent;
            border: 0;
        }

        .gv-device-events #gvEventPagerHost .gv-dt-info {
            flex: 0 0 auto;
        }

        .gv-device-events #gvEventPagerHost .gv-dt-pager {
            flex: 1 1 auto;
            display: flex;
            justify-content: flex-end;
            align-items: center;
            min-width: 0;
        }

        .gv-device-events #gvEventPagerHost .gv-dt-spacer {
            flex: 0 0 0;
            width: 0;
            height: 1px;
        }

        .gv-device-events #gvEventPagerHost .dataTables_paginate.paging_simple_numbers {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: transparent;
        }

        .gv-device-events #gvEventPagerHost .paginate_button {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: 1px solid #d5dbe7;
            background: #fff;
            color: #111827;
            text-decoration: none !important;
            user-select: none;
            cursor: pointer;
            box-sizing: border-box;
        }

            .gv-device-events #gvEventPagerHost .paginate_button.previous {
                width: 112px;
                height: 36px;
                font-size: 16px;
                font-weight: 600;
                border-radius: 4px;
                margin-right: 12px;
            }

            .gv-device-events #gvEventPagerHost .paginate_button.next {
                width: 82px;
                height: 36px;
                font-size: 16px;
                font-weight: 600;
                border-radius: 4px;
                margin-left: 12px;
            }

            .gv-device-events #gvEventPagerHost .paginate_button:not(.previous):not(.next) {
                width: 32px;
                height: 38px;
                border-radius: 2px;
                border-width: 1px;
                font-size: 16px;
                font-weight: 600;
                margin: 0;
            }

            .gv-device-events #gvEventPagerHost .paginate_button.current {
                background: #3e4cc1;
                color: #fff !important;
                border-color: #3e4cc1;
            }

            .gv-device-events #gvEventPagerHost .paginate_button.disabled {
                opacity: 0.5;
                pointer-events: none;
            }

        .gv-device-events #gvEventPagerHost {
            width: 100%;
            max-width: 1280px;
            box-sizing: border-box;
            margin-top: 14px;
            overflow: visible;
        }

    /* 3) Responsive with sidebar expand/collapse: allow full width */
    body:not(.admin-area) #wrapper.toggled.sidebar-expanded .gv-device-events .gv-events-topbar,
    body:not(.admin-area) #wrapper.toggled.sidebar-collapsed .gv-device-events .gv-events-topbar,
    body:not(.admin-area) #wrapper.toggled.sidebar-expanded .gv-device-events .gv-serial-bar,
    body:not(.admin-area) #wrapper.toggled.sidebar-collapsed .gv-device-events .gv-serial-bar,
    body:not(.admin-area) #wrapper.toggled.sidebar-expanded .gv-device-events .gv-card,
    body:not(.admin-area) #wrapper.toggled.sidebar-collapsed .gv-device-events .gv-card,
    body:not(.admin-area) #wrapper.toggled.sidebar-expanded .gv-device-events #gvEventPagerHost,
    body:not(.admin-area) #wrapper.toggled.sidebar-collapsed .gv-device-events #gvEventPagerHost {
        max-width: none;
    }

    @@media (max-width: 992px) {
        .gv-device-events .gv-search,
        .gv-device-events .gv-search input {
            width: 100%;
        }

        .gv-device-events #gvEventPagerHost .gv-dt-footer {
            flex-direction: column;
            align-items: flex-start;
        }

        .gv-device-events #gvEventPagerHost .gv-dt-spacer {
            display: none;
        }

        .gv-device-events .gv-dt-info {
            width: auto;
        }

        .gv-device-events #gvEventPagerHost .gv-dt-pager {
            justify-content: flex-start;
            width: 100%;
        }
    }
</style>

@section scripts
{
    @Scripts.Render("~/bundles/datetimescripts")
    <script type="text/javascript">
        function gvFormatDateTime(date) {
            var year = date.getFullYear();
            var month = ('0' + (date.getMonth() + 1)).slice(-2);
            var day = ('0' + date.getDate()).slice(-2);
            var hours = ('0' + date.getHours()).slice(-2);
            var minutes = ('0' + date.getMinutes()).slice(-2);
            return year + '/' + month + '/' + day + ' ' + hours + ':' + minutes;
        }

        function gvSetFiltersCollapsed(isCollapsed) {
            var $card = $('#gvFiltersCard');
            if (!$card.length) return;

            $card.toggleClass('is-collapsed', !!isCollapsed);

            try {
                if (window.sessionStorage) {
                    sessionStorage.setItem('gvDeviceEventsFiltersCollapsed', (!!isCollapsed).toString());
                }
            } catch (e) { }
        }

        function gvToggleFilters() {
            var $card = $('#gvFiltersCard');
            if (!$card.length) return;
            gvSetFiltersCollapsed(!$card.hasClass('is-collapsed'));
        }

        function gvRestoreFiltersCollapsed() {
            var v = null;
            try {
                if (window.sessionStorage) {
                    v = sessionStorage.getItem('gvDeviceEventsFiltersCollapsed');
                }
            } catch (e) { }

            if (v === 'true') {
                gvSetFiltersCollapsed(true);
            }
        }

        function gvRenderExternalPager(api) {
            var $pagerHost = $('#gvEventPagerHost');
            if (!$pagerHost.length) return;

            var pageInfo = api.page.info();
            var currentPage = pageInfo.page;
            var totalPages = pageInfo.pages;

            $pagerHost.empty();

            var $footer = $('<div class="gv-dt-footer"></div>');

            var infoText =
                'Showing ' + (pageInfo.recordsTotal ? (pageInfo.start + 1) : 0) +
                ' to ' + (pageInfo.recordsTotal ? pageInfo.end : 0) +
                ' of ' + pageInfo.recordsTotal +
                ' entries';

            var $infoBox = $('<div class="gv-dt-info"></div>').text(infoText);

            var $pager = $('<div class="gv-dt-pager"></div>');
            var $paginate = $('<div class="dataTables_paginate paging_simple_numbers"></div>');

            var $prev = $('<a href="#" class="paginate_button previous">&lt; Previous</a>');
            $prev.toggleClass('disabled', currentPage === 0);
            $prev.on('click', function (e) {
                e.preventDefault();
                if (currentPage === 0) return;
                api.page('previous').draw('page');
            });

            var $next = $('<a href="#" class="paginate_button next">Next &gt;</a>');
            $next.toggleClass('disabled', currentPage >= totalPages - 1);
            $next.on('click', function (e) {
                e.preventDefault();
                if (currentPage >= totalPages - 1) return;
                api.page('next').draw('page');
            });

            var maxButtons = 4;
            var startPage = Math.max(0, currentPage - Math.floor(maxButtons / 2));
            var endPage = Math.min(totalPages - 1, startPage + maxButtons - 1);

            if ((endPage - startPage) < (maxButtons - 1)) {
                startPage = Math.max(0, endPage - maxButtons + 1);
            }

            $paginate.append($prev);

            for (var i = startPage; i <= endPage; i++) {
                (function (pageIndex) {
                    var $btn = $('<a href="#" class="paginate_button"></a>');
                    $btn.text(pageIndex + 1);

                    if (pageIndex === currentPage) {
                        $btn.addClass('current');
                    }

                    $btn.on('click', function (e) {
                        e.preventDefault();
                        api.page(pageIndex).draw('page');
                    });

                    $paginate.append($btn);
                })(i);
            }

            $paginate.append($next);
            $pager.append($paginate);

            var $spacer = $('<div class="gv-dt-spacer" aria-hidden="true"></div>');

            $footer.append($infoBox).append($pager).append($spacer);
            $pagerHost.append($footer);
        }

        /* 3) Adjust DataTables columns when sidebar toggles (responsive initiative) */
        function gvTryAdjustEventTable() {
            try {
                if (!$.fn.DataTable) return;
                if (!$.fn.DataTable.isDataTable('#EventList')) return;

                var dt = $('#EventList').DataTable();
                dt.columns.adjust();
            } catch (e) { }
        }

        function gvBindSidebarAdjustOnce() {
            var toggleBtn = document.getElementById('sidebar-toggle');
            if (!toggleBtn || toggleBtn.__gvDeviceEventsBound) return;

            toggleBtn.__gvDeviceEventsBound = true;

            toggleBtn.addEventListener('click', function () {
                window.setTimeout(function () {
                    gvTryAdjustEventTable();
                }, 600);
            });
        }

        $(document).ready(function () {
            // Initialize datetimepickers with server-provided values
            // (Server already sets BeginDate to 2 hours ago in the controller)
            $('#fBeginDate').datetimepicker({
                mask: '9999/19/39 29:59',
                dayOfWeekStart: 1,
                lang: 'en',
                value: $('#fBeginDate').val(),
                step: 5
            });

            $('#fEndDate').datetimepicker({
                mask: '9999/19/39 29:59',
                dayOfWeekStart: 1,
                lang: 'en',
                value: $('#fEndDate').val(),
                step: 5
            });

            gvRestoreFiltersCollapsed();

            $('#gvFiltersHeader').on('click', function () {
                gvToggleFilters();
            });

            $('#gvEventsRefresh').off('click.gv').on('click.gv', function (e) {
                e.preventDefault();
                window.location.reload();
            });

            gvBindSidebarAdjustOnce();
            $(window).on('resize', function () { gvTryAdjustEventTable(); });

            if ($.fn.DataTable.isDataTable('#EventList')) {
                $('#EventList').DataTable().destroy();
            }

            $('#gvEventPagerHost').empty();

            var table = $('#EventList').DataTable({
                dom: 't',
                paging: true,
                pageLength: 10,
                lengthChange: false,
                searching: true,
                ordering: false,
                info: false,
                autoWidth: false,
                search: {
                    smart: true,
                    regex: false,
                    caseInsensitive: true
                },
                drawCallback: function () {
                    gvRenderExternalPager(this.api());
                },
                createdRow: function (row, data) {
                    var eventType = (data && data.length >= 3) ? (data[2] || '') : '';
                    if (eventType === 'INFO') {
                        $('td', row).addClass('text-success');
                    } else if (eventType === 'WARN') {
                        $('td', row).addClass('text-warning');
                    } else if (eventType === 'ERROR') {
                        $('td', row).addClass('text-danger');
                    }
                }
            });

            gvRenderExternalPager(table);

            $(document)
                .off('input.gvDeviceEventsSearch keyup.gvDeviceEventsSearch', '#gvEventSearch')
                .on('input.gvDeviceEventsSearch keyup.gvDeviceEventsSearch', '#gvEventSearch', function () {
                    table.search(this.value).draw();
                });

            new $.fn.dataTable.Buttons(table, {
                buttons: [
                    {
                        extend: 'excelHtml5',
                        text: 'Download (*.xlsx)',
                        filename: 'Event List',
                        exportOptions: {
                            columns: [0, 1, 2, 3, 4]
                        }
                    }
                ]
            });

            $('#gvEventDownload').on('click', function (e) {
                e.preventDefault();
                if (!table || !table.button) return;
                if (!table.buttons || !table.buttons().count()) return;
                table.button(0).trigger();
            });

            gvTryAdjustEventTable();
        });
    </script>

    @if (Model == null || Model.EventList == null || !Model.EventList.Any())
    {
        if (Request["gvAutoApplied"] != "true")
        {
            <script type="text/javascript">
                $(function () {
                    alertify.alert('Geni-View Cloud', 'No data found matching the given filter criteria');
                });
            </script>
        }
    }
}

<div class="gv-device-events">
    <!-- Event History blue bar + Refresh -->
    <div class="gv-events-topbar" role="region" aria-label="Event History header">
        <div class="gv-events-topbar__title">Event History</div>
        <div class="gv-events-topbar__spacer"></div>
        <button type="button" id="gvEventsRefresh" class="refresh-btn" title="Refresh">
            <i class="fa fa-sync refresh-icon" aria-hidden="true"></i>
            <span>Refresh</span>
        </button>
    </div>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()

        <div class="row">
            <div class="col-xs-12">
                <!-- Filters card -->
                <div class="gv-card" id="gvFiltersCard">
                    <div class="gv-card__header" id="gvFiltersHeader" role="button" aria-controls="gvFiltersBody" aria-expanded="true">
                        <div class="gv-card__title">
                            <img class="gv-icon" src="@Url.Content("~/Content/Img/widgets/Filters.svg")" alt="Filters" />
                            <span>Filters</span>
                        </div>

                        <span class="gv-card__chevron" aria-hidden="true">
                            <img src="@Url.Content("~/Content/Img/widgets/poly.svg")" alt="" />
                        </span>
                    </div>

                    <div class="gv-card__body" id="gvFiltersBody">
                        <div class="gv-filters-grid">
                            <div class="gv-field">
                                <label for="fBeginDate">Begin Date</label>
                                <div class="gv-input-icon">
                                    <input type="text" class="gv-input gv-input--date" id="fBeginDate" name="BeginDate" value="@(Model != null && Model.BeginDate != DateTime.MinValue ? Model.BeginDate.ToString("yyyy/MM/dd HH:mm") : "")" />
                                    <span class="gv-input-icon__suffix" aria-hidden="true">
                                        <img class="gv-icon" src="@Url.Content("~/Content/Img/widgets/Date.svg")" alt="" />
                                    </span>
                                </div>
                            </div>

                            <div class="gv-field">
                                <label for="fEndDate">End Date</label>
                                <div class="gv-input-icon">
                                    <input type="text" class="gv-input gv-input--date" id="fEndDate" name="EndDate" value="@(Model != null && Model.EndDate != DateTime.MinValue ? Model.EndDate.ToString("yyyy/MM/dd HH:mm") : "")" />
                                    <span class="gv-input-icon__suffix" aria-hidden="true">
                                        <img class="gv-icon" src="@Url.Content("~/Content/Img/widgets/Date.svg")" alt="" />
                                    </span>
                                </div>
                            </div>

                            <div class="gv-field">
                                <label for="Count">Events Count</label>
                                @Html.EditorFor(model => model.Count, new { htmlAttributes = new { @class = "gv-input gv-input--count", @Value = Model.Count } })
                            </div>

                            <div class="gv-field">
                                <label>&nbsp;</label>
                                <button type="submit" id="gvApplyFilters" class="gv-btn gv-btn--primary">Apply Filters</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div>@Html.ValidationMessage("DbFail", new { @class = "text-danger" })</div>

                <!-- Event List bar -->
                <div class="gv-serial-bar" role="region" aria-label="Event list and search">
                    <div class="gv-serial-bar__left">
                        Event List : @ViewBag.DeviceSerialNumber
                    </div>

                    <div class="gv-search">
                        <i class="fa fa-search" aria-hidden="true"></i>
                        <input id="gvEventSearch"
                               type="text"
                               placeholder="Search by Device Serial Number........"
                               aria-label="Search events" />
                    </div>

                    <a id="gvEventDownload" href="#" class="gv-btn gv-btn--primary">Download(*.xlsx)</a>
                </div>

                <!-- Table card -->
                <div class="gv-card gv-table-card" style="max-width:none; margin-top:14px;">
                    <div class="gv-card__body">
                        <div class="gv-table-scroll">
                            <table class="gv-table" id="EventList">
                                <thead>
                                    <tr>
                                        <th class="text-center">@Html.DisplayName("Serial Number")</th>
                                        <th class="text-center">@Html.DisplayName("Description")</th>
                                        <th class="text-center">@Html.DisplayName("Event Type")</th>
                                        <th class="text-center">@Html.DisplayName("Source")</th>
                                        <th class="text-center">@Html.DisplayName("Timestamp")</th>
                                    </tr>
                                </thead>

                                @if (Model.EventList != null)
                                {
                                    <tbody>
                                        @foreach (var item in Model.EventList)
                                        {
                                            <tr>
                                                <td class="text-center">
                                                    <span class="gv-cell-prefix">
                                                        <img src="@Url.Content("~/Content/Img/widgets/Event1.svg")" alt="" aria-hidden="true" />
                                                        <span>@Html.DisplayFor(modelItem => item.DeviceSerialNumber)</span>
                                                    </span>
                                                </td>
                                                <td class="text-center">@Html.DisplayFor(modelItem => item.Description)</td>
                                                <td class="text-center">
                                                    <span class="gv-cell-prefix">
                                                        <img src="@Url.Content("~/Content/Img/widgets/Event2.svg")" alt="" aria-hidden="true" />
                                                        <span>@Html.DisplayFor(modelItem => item.EventType)</span>
                                                    </span>
                                                </td>
                                                <td class="text-center">@item.SourceText</td>
                                                <td class="text-right">
                                                    <span class="gv-cell-inline">
                                                        <img src="@Url.Content("~/Content/Img/widgets/Event3.svg")" alt="" aria-hidden="true" />
                                                        <span>@TimeZoneHelper.GetLocalDateTime(item.Timestamp, ViewBag.CurrentUser)</span>
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                }
                            </table>
                        </div>
                    </div>
                </div>

                <!-- External pagination footer -->
                <div id="gvEventPagerHost"></div>
            </div>
        </div>
    }
</div>